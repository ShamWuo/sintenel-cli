# Gemini API key
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_key_here

# Main orchestrator model (default: gemini-3-flash-preview)
# GEMINI_MODEL=gemini-3-flash-preview

# Sub-agent model (Scout/Fixer) - cheaper by default
# AI_SUBAGENT_MODEL=gemini-3.1-flash-lite-preview

# High-assurance hardening options
# Strict mode is secure-by-default (set false only for controlled lab scenarios):
# SINTENEL_STRICT_MODE=true
# Require second challenge phrase after Y/N approval:
# SINTENEL_HIGH_ASSURANCE_APPROVAL=true
# Enable HMAC-signed tamper-evident audit chain:
# SINTENEL_AUDIT_HMAC_KEY=replace_with_long_random_secret
# Keep destructive file operations disabled by default:
# SINTENEL_ALLOW_DESTRUCTIVE_OPS=false
# Max times a single approved command may run in one session:
# SINTENEL_MAX_EXECUTIONS_PER_COMMAND=3
# Max LLM turns before forced safe abort:
# SINTENEL_MAX_SESSION_TURNS=18

