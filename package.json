{
  "name": "sintenel-cli",
  "version": "0.2.2",
  "description": "AI-powered multi-agent security orchestrator with human-in-the-loop safety, tamper-evident audits, and cost-optimized workflows",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "sintenel": "./dist/sintenel.cjs",
    "Sintenel": "./dist/sintenel.cjs"
  },
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc",
    "bundle": "node scripts/bundle.js",
    "dev": "node --import tsx src/index.ts",
    "start": "node dist/sintenel.cjs",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "benchmark": "node scripts/benchmark.js",
    "analyze-costs": "node scripts/analyze-costs.js",
    "generate-report": "node scripts/generate-report.js",
    "compile": "node scripts/compile.js",
    "postinstall": "npm run bundle"
  },
  "keywords": [
    "security",
    "ai",
    "cli",
    "orchestrator",
    "vulnerability-scanning",
    "red-team",
    "blue-team",
    "devsecops",
    "audit",
    "compliance",
    "gemini",
    "multi-agent"
  ],
  "author": "Sintenel Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShamWuo/sintenel-cli.git"
  },
  "bugs": {
    "url": "https://github.com/ShamWuo/sintenel-cli/issues"
  },
  "homepage": "https://github.com/ShamWuo/sintenel-cli#readme",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.75",
    "@ai-sdk/google": "^3.0.67",
    "@ai-sdk/openai": "^3.0.60",
    "@inquirer/prompts": "^8.4.2",
    "ai": "^6.0.175",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "esbuild": "^0.27.7",
    "inquirer": "^13.3.2",
    "keytar": "^7.9.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "ora": "^9.3.0",
    "typescript": "^5.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/inquirer": "^9.0.9",
    "@types/marked": "^5.0.2",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "happy-dom": "^20.8.8",
    "pkg": "^5.8.1",
    "tsx": "^4.19.3",
    "vitest": "^4.1.2"
  },
  "pkg": {
    "assets": [
      "scripts/security/**/*"
    ]
  }
}
